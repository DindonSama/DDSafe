# ── PocketBase ────────────────────────────────────────────────────────────────
PB_ADMIN_EMAIL=admin@admin.com
PB_ADMIN_PASSWORD=Admin12345!
# Port d'exposition de l'interface PocketBase Admin (défaut : 8090)
PB_PORT=8090

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=DDSafe
# Clé secrète pour le chiffrement des secrets OTP (libsodium).
# IMPORTANT : ne jamais modifier après la première utilisation.
APP_SECRET=change-me-with-a-long-random-string-here
# Port d'exposition de l'application web (défaut : 8080)
APP_PORT=8080
# Activer les codes OTP personnels (non liés à un tenant)
PERSONAL_CODES_ENABLED=false
# Expiration de session en secondes (défaut : 900 = 15 min)
SESSION_TIMEOUT_SECONDS=900
# Nombre max d'entrées conservées pour les journaux (audit et échecs auth)
LOG_MAX_ENTRIES=500
# Rétention des journaux en jours
LOG_RETENTION_DAYS=30

# Premier compte administrateur applicatif (créé automatiquement au premier lancement)
APP_ADMIN_EMAIL=admin@2fa-manager.local
APP_ADMIN_PASSWORD=admin123
APP_ADMIN_NAME=Administrateur

# URL par défaut de l'application DDSafe dans l'extension (popup/options)
EXTENSION_APP_URL=http://localhost:8080

# ── LDAP / Active Directory ───────────────────────────────────────────────────
LDAP_ENABLED=false
LDAP_HOST=
LDAP_PORT=389
LDAP_BASE_DN=
LDAP_DOMAIN=
LDAP_USE_SSL=false
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_SEARCH_FILTER=(sAMAccountName={username})

# ── OIDC (SSO) ────────────────────────────────────────────────────────────────
OIDC_ENABLED=false
OIDC_PROVIDER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_SCOPES=openid profile email
OIDC_USERNAME_CLAIM=preferred_username
OIDC_BUTTON_LABEL=Se connecter via SSO

# Fuseau horaire
TZ=Europe/Paris
