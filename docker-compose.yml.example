services:
  pb_2fa:
    image: ghcr.io/muchobien/pocketbase:0.36
    environment:
      PB_ADMIN_EMAIL: "${PB_ADMIN_EMAIL:-admin@admin.com}"
      PB_ADMIN_PASSWORD: "${PB_ADMIN_PASSWORD:-Admin12345!}"
    volumes:
      - ./pb_data:/pb_data
    ports:
      - "${PB_PORT:-8090}:8090"
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://localhost:8090/api/health"]
      interval: 5s
      timeout: 3s
      retries: 10
      start_period: 30s

  php:
    image: php:8.2-apache
    volumes:
      - ./web/app:/var/www/app
      - ./web/scripts/php-start.sh:/start.sh:ro
      - ./web/scripts/backup-scheduler.php:/scheduler/backup-scheduler.php:ro
      - ./web/composer:/usr/local/bin/composer_cache
      - ./backups:/backups
    ports:
      - "${APP_PORT:-8080}:80"
    environment:
      POCKETBASE_URL: "http://pb_2fa:8090"
      PB_ADMIN_EMAIL: "${PB_ADMIN_EMAIL:-admin@admin.com}"
      PB_ADMIN_PASSWORD: "${PB_ADMIN_PASSWORD:-Admin12345!}"
      LDAP_ENABLED: "${LDAP_ENABLED:-false}"
      LDAP_HOST: "${LDAP_HOST:-}"
      LDAP_PORT: "${LDAP_PORT:-389}"
      LDAP_BASE_DN: "${LDAP_BASE_DN:-}"
      LDAP_DOMAIN: "${LDAP_DOMAIN:-}"
      LDAP_USE_SSL: "${LDAP_USE_SSL:-false}"
      LDAP_BIND_DN: "${LDAP_BIND_DN:-}"
      LDAP_BIND_PASSWORD: "${LDAP_BIND_PASSWORD:-}"
      LDAP_SEARCH_FILTER: "${LDAP_SEARCH_FILTER:-}"
      OIDC_ENABLED: "${OIDC_ENABLED:-false}"
      OIDC_PROVIDER_URL: "${OIDC_PROVIDER_URL:-}"
      OIDC_CLIENT_ID: "${OIDC_CLIENT_ID:-}"
      OIDC_CLIENT_SECRET: "${OIDC_CLIENT_SECRET:-}"
      OIDC_REDIRECT_URI: "${OIDC_REDIRECT_URI:-}"
      OIDC_SCOPES: "${OIDC_SCOPES:-openid profile email}"
      OIDC_USERNAME_CLAIM: "${OIDC_USERNAME_CLAIM:-preferred_username}"
      OIDC_BUTTON_LABEL: "${OIDC_BUTTON_LABEL:-Se connecter via SSO}"
      APP_SECRET: "${APP_SECRET:-change-me-with-a-long-random-string-here}"
      APP_NAME: "${APP_NAME:-DDSafe}"
      PERSONAL_CODES_ENABLED: "${PERSONAL_CODES_ENABLED:-false}"
      SESSION_TIMEOUT_SECONDS: "${SESSION_TIMEOUT_SECONDS:-900}"
      LOG_MAX_ENTRIES: "${LOG_MAX_ENTRIES:-500}"
      APP_ADMIN_EMAIL: "${APP_ADMIN_EMAIL:-admin@2fa-manager.local}"
      APP_ADMIN_PASSWORD: "${APP_ADMIN_PASSWORD:-admin123}"
      APP_ADMIN_NAME: "${APP_ADMIN_NAME:-Administrateur}"
      EXTENSION_APP_URL: "${EXTENSION_APP_URL:-http://localhost:8080}"
      BACKUP_SCHEDULER_ENABLED: "${BACKUP_SCHEDULER_ENABLED:-false}"
      BACKUP_SCHEDULES: "${BACKUP_SCHEDULES:-daily,weekly,monthly}"
      BACKUP_RUN_HOUR: "${BACKUP_RUN_HOUR:-2}"
      BACKUP_WEEKLY_DAY: "${BACKUP_WEEKLY_DAY:-7}"
      BACKUP_MONTHLY_DAY: "${BACKUP_MONTHLY_DAY:-1}"
      BACKUP_EXPORT_MODE: "${BACKUP_EXPORT_MODE:-encrypted}"
      BACKUP_INCLUDE_SECRETS: "${BACKUP_INCLUDE_SECRETS:-false}"
      BACKUP_PASSPHRASE: "${BACKUP_PASSPHRASE:-}"
      BACKUP_OUTPUT_DIR: "/backups"
      BACKUP_RETENTION_DAILY: "${BACKUP_RETENTION_DAILY:-14}"
      BACKUP_RETENTION_WEEKLY: "${BACKUP_RETENTION_WEEKLY:-8}"
      BACKUP_RETENTION_MONTHLY: "${BACKUP_RETENTION_MONTHLY:-12}"
      BACKUP_CHECK_INTERVAL_SECONDS: "${BACKUP_CHECK_INTERVAL_SECONDS:-300}"
      TZ: "${TZ:-Europe/Paris}"
    depends_on:
      pb_2fa:
        condition: service_healthy
    entrypoint: ["bash", "/start.sh"]
    restart: unless-stopped

